# Enable MPU
CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y

# Enable hardware acceleration for crypto
CONFIG_ENTROPY_NRF5_RNG=y

# Enable GPIO
CONFIG_GPIO=y

# Enable UART for serial modem (async API, no hardware flow control)
CONFIG_SERIAL=y
CONFIG_UART_NRFX=y
CONFIG_UART_ASYNC_API=y
CONFIG_UART_0_ASYNC=y
CONFIG_UART_0_INTERRUPT_DRIVEN=n

# Enable USB for console/shell (new USB device stack)
CONFIG_USB_DEVICE_STACK_NEXT=y
CONFIG_UART_USE_RUNTIME_CONFIGURE=y
CONFIG_USBD_CDC_ACM_CLASS=y
CONFIG_CDC_ACM_SERIAL_INITIALIZE_AT_BOOT=y
CONFIG_CDC_ACM_SERIAL_MANUFACTURER_STRING="nRFModule"
CONFIG_CDC_ACM_SERIAL_PRODUCT_STRING="LiveTracker"
CONFIG_CDC_ACM_SERIAL_PID=0x0005
CONFIG_USBD_LOG_LEVEL_WRN=y
CONFIG_UDC_BUF_POOL_SIZE=8192
# Enable I2C for sensors (accelerometer, barometer)
CONFIG_I2C=y
CONFIG_I2C_NRFX=y

# Enable QSPI for external flash
CONFIG_SPI=y
CONFIG_NORDIC_QSPI_NOR=y
