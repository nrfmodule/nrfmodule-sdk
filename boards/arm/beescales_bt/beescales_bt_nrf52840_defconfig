# Enable MPU
CONFIG_ARM_MPU=y
CONFIG_HW_STACK_PROTECTION=y

# Enable hardware acceleration for crypto
CONFIG_ENTROPY_NRF5_RNG=y

# Enable GPIO
CONFIG_GPIO=y

# Enable I2C for sensors (accelerometer, RTC)
CONFIG_I2C=y
CONFIG_I2C_NRFX=y

# Enable QSPI for external flash
CONFIG_NORDIC_QSPI_NOR=y
CONFIG_NORDIC_QSPI_NOR_FLASH_LAYOUT_PAGE_SIZE=4096

# Enable PWM for LED control
CONFIG_PWM=y

# Enable ADC for battery measurement
CONFIG_ADC=y
